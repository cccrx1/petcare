{
  "version": "1.0.0",
  "description": "AI宠物健康管理系统 - API接口统一配置文件",
  "dify": {
    "base_url": "http://47.113.151.36//v1",
    "api_key": "",
    "timeout": 30000
  },
  "api": {
    "base_url": "",
    "version": "v1",
    "timeout": 30000
  },
  "endpoints": {
    "user": {
      "register": {
        "path": "/users/register",
        "method": "POST",
        "description": "用户注册"
      },
      "login": {
        "path": "/users/login",
        "method": "POST",
        "description": "用户登录"
      },
      "profile": {
        "path": "/users/profile",
        "method": "GET",
        "description": "获取用户资料"
      },
      "update_profile": {
        "path": "/users/profile",
        "method": "PUT",
        "description": "更新用户资料"
      }
    },
    "pet": {
      "create": {
        "path": "/pets",
        "method": "POST",
        "description": "创建宠物档案"
      },
      "list": {
        "path": "/pets",
        "method": "GET",
        "description": "获取宠物列表"
      },
      "detail": {
        "path": "/pets/{id}",
        "method": "GET",
        "description": "获取宠物详情"
      },
      "update": {
        "path": "/pets/{id}",
        "method": "PUT",
        "description": "更新宠物档案"
      },
      "delete": {
        "path": "/pets/{id}",
        "method": "DELETE",
        "description": "删除宠物档案"
      }
    },
    "health_monitoring": {
      "create_record": {
        "path": "/health/records",
        "method": "POST",
        "description": "创建健康监测记录"
      },
      "get_records": {
        "path": "/health/records/{pet_id}",
        "method": "GET",
        "description": "获取健康监测记录"
      },
      "get_trends": {
        "path": "/health/trends/{pet_id}",
        "method": "GET",
        "description": "获取健康趋势图表数据"
      }
    },
    "alerts": {
      "list": {
        "path": "/alerts",
        "method": "GET",
        "description": "获取预警列表"
      },
      "detail": {
        "path": "/alerts/{id}",
        "method": "GET",
        "description": "获取预警详情"
      },
      "mark_read": {
        "path": "/alerts/{id}/read",
        "method": "PUT",
        "description": "标记预警已读"
      }
    },
    "veterinary": {
      "consultation": {
        "path": "/veterinary/consultation",
        "method": "POST",
        "description": "发起兽医咨询"
      },
      "appointment": {
        "path": "/veterinary/appointment",
        "method": "POST",
        "description": "预约线下服务"
      },
      "medical_records": {
        "path": "/veterinary/records/{pet_id}",
        "method": "GET",
        "description": "获取宠物病历"
      }
    },
    "feeding": {
      "plan": {
        "path": "/feeding/plan/{pet_id}",
        "method": "GET",
        "description": "获取喂养方案"
      },
      "adjust": {
        "path": "/feeding/adjust/{pet_id}",
        "method": "POST",
        "description": "调整喂养方案"
      },
      "recipes": {
        "path": "/feeding/recipes/{pet_id}",
        "method": "GET",
        "description": "获取食谱建议"
      }
    },
    "training": {
      "problems": {
        "path": "/training/problems",
        "method": "GET",
        "description": "获取行为问题库"
      },
      "solution": {
        "path": "/training/solution/{problem_id}",
        "method": "GET",
        "description": "获取纠正方案"
      },
      "plan": {
        "path": "/training/plan",
        "method": "POST",
        "description": "创建训练计划"
      },
      "check_in": {
        "path": "/training/check-in/{plan_id}",
        "method": "POST",
        "description": "训练打卡"
      }
    },
    "community": {
      "feed": {
        "path": "/community/feed",
        "method": "GET",
        "description": "获取社区动态"
      },
      "post": {
        "path": "/community/posts",
        "method": "POST",
        "description": "发布帖子"
      },
      "comments": {
        "path": "/community/posts/{post_id}/comments",
        "method": "GET",
        "description": "获取评论"
      },
      "news": {
        "path": "/community/news",
        "method": "GET",
        "description": "获取热点资讯"
      }
    },
    "chat": {
      "send_message": {
        "path": "/chat/message",
        "method": "POST",
        "description": "发送聊天消息",
        "agent_integration": "pet-health-assistant"
      },
      "history": {
        "path": "/chat/history",
        "method": "GET",
        "description": "获取聊天历史"
      }
    }
  },
  "authentication": {
    "type": "JWT",
    "token_expiry": 86400,
    "refresh_token_expiry": 604800,
    "header_name": "Authorization",
    "header_prefix": "Bearer"
  },
  "database": {
    "primary": {
      "type": "PostgreSQL",
      "host": "",
      "port": 5432,
      "database": "",
      "username": "",
      "password": ""
    },
    "timeseries": {
      "type": "InfluxDB",
      "host": "",
      "port": 8086,
      "database": "",
      "username": "",
      "password": ""
    }
  },
  "notification": {
    "enabled": true,
    "channels": [
      "push",
      "email",
      "sms"
    ],
    "push_config": {
      "service": "",
      "api_key": ""
    }
  },
  "iot": {
    "enabled": true,
    "devices": {
      "smart_collar": {
        "enabled": true,
        "data_points": [
          "steps",
          "sleep_quality",
          "activity_level"
        ]
      },
      "smart_feeder": {
        "enabled": true,
        "data_points": [
          "food_intake",
          "feeding_speed",
          "feeding_times"
        ]
      }
    }
  }
}
